rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin kontrolü
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'berke.parlat27@gmail.com';
    }
    
    // Tasks koleksiyonu
    match /tasks/{taskId} {
      // Kullanıcı giriş yapmış olmalı
      allow read: if request.auth != null;
      
      // Yeni görev oluşturma
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid;
      
      // Görev güncelleme ve silme (kendi görevi veya admin)
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid || isAdmin());
    }
    
    // Users koleksiyonu
    match /users/{userId} {
      allow read: if request.auth != null;
      // Kullanıcı kendi bilgilerini güncelleyebilir VEYA admin tüm kullanıcıları güncelleyebilir
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
    
    // Messages koleksiyonu
    match /messages/{messageId} {
      // Giriş yapmış kullanıcılar mesaj gönderebilir
      allow create: if request.auth != null 
                    && request.resource.data.senderId == request.auth.uid;
      
      // Kullanıcı sadece kendisine gelen mesajları okuyabilir (veya admin)
      allow read: if request.auth != null 
                  && (resource.data.recipientId == request.auth.uid 
                      || resource.data.senderId == request.auth.uid
                      || isAdmin());
      
      // Kullanıcı sadece kendisine gelen mesajları güncelleyebilir (okundu işareti için)
      allow update: if request.auth != null 
                    && (resource.data.recipientId == request.auth.uid || isAdmin());
      
      // Mesaj silme - gönderen veya alan silebilir veya admin
      allow delete: if request.auth != null 
                    && (resource.data.recipientId == request.auth.uid 
                        || resource.data.senderId == request.auth.uid
                        || isAdmin());
    }
    
    // Departments koleksiyonu (admin paneli için)
    match /departments/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Diğer tüm koleksiyonları engelle
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
